# ─── agent-x-cc configuration ────────────────────────────────────────────────
# Copy to .env and fill in only the engines you plan to use.

# Default engine when --engine is omitted (claude-code | codex | hermes)
AGENT_X_ENGINE=claude-code

# ── Claude Code (Anthropic) ──────────────────────────────────────────────────
# Install: npm i -g @anthropic-ai/claude-code
ANTHROPIC_API_KEY=
# Override the binary path if `claude` is not on PATH
# CLAUDE_BIN=claude

# ── OpenAI Codex ─────────────────────────────────────────────────────────────
# Install: npm i -g @openai/codex
OPENAI_API_KEY=
# CODEX_BIN=codex

# ── Nous Hermes (HTTP, OpenAI-compatible) ────────────────────────────────────
HERMES_API_KEY=
HERMES_BASE_URL=https://inference-api.nousresearch.com/v1
HERMES_MODEL=Hermes-4-405B
